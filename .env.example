PORT=3010
PRICING_API_KEY=defina_um_segredo_longo_compartilhado_com_o_backend

# Chamada serviço-a-serviço ao backend (Nest) para disparar o backfill agendado.
# No Docker Compose: http://backend:3000
# BACKEND_INTERNAL_URL=http://backend:3000
# Segredo partilhado (igual a INTERNAL_PRICE_BACKFILL_SECRET no backend)
# INTERNAL_PRICE_BACKFILL_SECRET=

# Opcional: mesmo Redis do stack (recomendado para cache de preços)
REDIS_HOST=redis
REDIS_PORT=6379

# Rate limit (busca por IP)
SEARCH_RATE_LIMIT_WINDOW_MS=60000
SEARCH_RATE_LIMIT_MAX=40

# Rate limit global /v1 (por IP)
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=300

LOG_LEVEL=info

# ENABLE_CRON=true
# ENABLE_PRICE_BACKFILL_CRON=true
# PRICE_BACKFILL_CRON=15 */2 * * *
# PRICE_BACKFILL_HTTP_TIMEOUT_MS=600000
