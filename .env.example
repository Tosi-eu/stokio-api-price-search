PORT=3010
NODE_ENV=development

# Postgres (Compose: DB_HOST=postgres DB_PORT=5432)
DB_HOST=localhost
DB_PORT=5432
STOKIO_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/estoque?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379

# Chamadas internas ao backend Nest (ingestão de erros, etc.)
BACKEND_INTERNAL_URL=http://localhost:3000

ENABLE_CRON=true
LOG_LEVEL=info
